# AI API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
DEEPSEEK_API_KEY=...

# Local Service URLs
OLLAMA_URL=http://localhost:11434
STABLE_DIFFUSION_URL=http://localhost:7860
COMFYUI_URL=http://localhost:8188
LM_STUDIO_URL=http://localhost:1234

# Server Config
PORT=3001
FRONTEND_URL=http://localhost:3000

# Sync Config
SYNC_SOURCE_DIR=/path/to/ai-art
SYNC_TARGET_DIR=/path/to/mini-pc-share

# Persistent Assistant (Aria)
# Path to the JSON file where Aria stores her memory (user prefs, projects, notes, team)
MEMORY_FILE=./data/memory.json
# Customise the assistant's name
ASSISTANT_NAME=Aria
# Optional: GitHub personal access token for GitHub-aware context (read-only scopes sufficient)
GITHUB_TOKEN=

# Security — API key for write/delete memory routes and agent endpoints.
# If left blank these routes require no authentication (suitable for local-only installs).
# Set to a long random string when the server is publicly accessible.
API_SECRET_KEY=

# Paperclip (file uploads)
# Directory where uploaded files are stored (default: ./data/uploads)
UPLOAD_DIR=./data/uploads
# Maximum upload size in megabytes (default: 10)
UPLOAD_MAX_MB=10
